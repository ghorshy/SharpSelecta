<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <x:Double x:Key="Spacing.None">0</x:Double>
    <x:Double x:Key="Spacing.XXS">2</x:Double>
    <x:Double x:Key="Spacing.XS">4</x:Double>
    <x:Double x:Key="Spacing.S">6</x:Double>
    <x:Double x:Key="Spacing.M">10</x:Double>
    <x:Double x:Key="Spacing.L">16</x:Double>

</ResourceDictionary>
