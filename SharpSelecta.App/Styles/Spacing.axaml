<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Spacing scale (px) — single source of truth for margins/paddings/stack spacing across the
         app. Named after the step, not after whatever control happens to use it today, so the same
         token is reused wherever that step is needed. -->
    <x:Double x:Key="SpacingXXS">2</x:Double>
    <x:Double x:Key="SpacingXS">4</x:Double>
    <x:Double x:Key="SpacingS">6</x:Double>
    <x:Double x:Key="SpacingM">10</x:Double>

    <!-- Thickness presets built from the scale above, for the margin shapes actually used in the
         views. Avalonia can't compose a Thickness from a resource inline (e.g. "0,{StaticResource
         SpacingM},0,0"), so each shape needed gets its own named preset here instead. -->
    <Thickness x:Key="ThicknessUniformM">10</Thickness>
    <Thickness x:Key="ThicknessTopM">0,10,0,0</Thickness>
    <Thickness x:Key="ThicknessBottomM">0,0,0,10</Thickness>
    <Thickness x:Key="ThicknessTopS">0,6,0,0</Thickness>
    <Thickness x:Key="ThicknessVerticalXXS">0,2</Thickness>
    <Thickness x:Key="ThicknessHorizontalXS">4,0</Thickness>
    <Thickness x:Key="ThicknessLeftXS">4,0,0,0</Thickness>

</ResourceDictionary>
