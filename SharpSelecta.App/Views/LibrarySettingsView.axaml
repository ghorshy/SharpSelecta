<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SharpSelecta.App.ViewModels"
             xmlns:res="using:SharpSelecta.App.Resources"
             xmlns:styles="using:SharpSelecta.App.Styles"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="200"
             x:Class="SharpSelecta.App.Views.LibrarySettingsView"
             x:DataType="vm:LibraryViewModel">

    <StackPanel Spacing="{styles:SpacingValue S}">
        <TextBlock Text="{Binding DisplayLibraryFolderPath}" TextWrapping="Wrap" />
        <Button Content="{x:Static res:Strings.ChooseLibraryFolder}" Command="{Binding ChooseFolderCommand}" HorizontalAlignment="Left" />
    </StackPanel>

</UserControl>
