<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SharpSelecta.App.ViewModels"
             xmlns:res="using:SharpSelecta.App.Resources"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="400"
             x:Class="SharpSelecta.App.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

    <Grid>
        <!-- Empty state: no library folder chosen (or remembered) yet — the button takes center
             stage as an invitation, instead of sitting small at the top above an empty list. -->
        <StackPanel IsVisible="{Binding NoTracks}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
            <Button Content="{x:Static res:Strings.ChooseLibraryFolder}" Command="{Binding ChooseFolderCommand}" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="OrangeRed" TextWrapping="Wrap" HorizontalAlignment="Center" IsVisible="{Binding StatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
        </StackPanel>

        <DockPanel IsVisible="{Binding HasTracks}" LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,10">
                <Button Content="{x:Static res:Strings.ChooseLibraryFolder}" Command="{Binding ChooseFolderCommand}" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="OrangeRed" TextWrapping="Wrap" IsVisible="{Binding StatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
            </StackPanel>

            <DataGrid ItemsSource="{Binding Tracks}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      DoubleTapped="OnTrackDoubleTapped">
                <DataGrid.Styles>
                    <!-- Right-click on a column header: choose which columns are visible. -->
                    <Style Selector="DataGridColumnHeader">
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <MenuItem Header="{x:Static res:Strings.ColumnTrack}" ToggleType="CheckBox" IsChecked="{Binding IsTrackNumberColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnTitle}" ToggleType="CheckBox" IsChecked="{Binding IsTitleColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnArtist}" ToggleType="CheckBox" IsChecked="{Binding IsArtistColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnAlbum}" ToggleType="CheckBox" IsChecked="{Binding IsAlbumColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnLength}" ToggleType="CheckBox" IsChecked="{Binding IsLengthColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnSampleRate}" ToggleType="CheckBox" IsChecked="{Binding IsSampleRateColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnBitDepth}" ToggleType="CheckBox" IsChecked="{Binding IsBitDepthColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnBitrate}" ToggleType="CheckBox" IsChecked="{Binding IsBitrateColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnFileType}" ToggleType="CheckBox" IsChecked="{Binding IsFileTypeColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnYear}" ToggleType="CheckBox" IsChecked="{Binding IsYearColumnVisible, Mode=TwoWay}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- Right-click on a row: same Play Now/Play Next/Add to Queue actions as
                         before, now on DataGridRow instead of ListBoxItem. -->
                    <Style Selector="DataGridRow">
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu x:DataType="vm:LibraryTrackViewModel">
                                    <MenuItem Header="{x:Static res:Strings.PlayNow}"
                                              Command="{Binding Library.PlayNowCommand}"
                                              CommandParameter="{Binding Track}" />
                                    <MenuItem Header="{x:Static res:Strings.PlayNext}"
                                              Command="{Binding Library.PlayNextCommand}"
                                              CommandParameter="{Binding Track}" />
                                    <MenuItem Header="{x:Static res:Strings.AddToQueue}"
                                              Command="{Binding Library.AddToQueueCommand}"
                                              CommandParameter="{Binding Track}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Styles>

                <DataGrid.Columns>
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnTrack}" Binding="{Binding Track.TrackNumber}" IsVisible="{Binding IsTrackNumberColumnVisible}" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnTitle}" Binding="{Binding Track.Title}" IsVisible="{Binding IsTitleColumnVisible}" Width="200" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnArtist}" Binding="{Binding Track.Artist}" IsVisible="{Binding IsArtistColumnVisible}" Width="150" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnAlbum}" Binding="{Binding Track.Album}" IsVisible="{Binding IsAlbumColumnVisible}" Width="150" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnLength}" Binding="{Binding Track.LengthDisplay}" IsVisible="{Binding IsLengthColumnVisible}" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnSampleRate}" Binding="{Binding Track.SampleRateDisplay}" IsVisible="{Binding IsSampleRateColumnVisible}" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnBitDepth}" Binding="{Binding Track.BitDepthDisplay}" IsVisible="{Binding IsBitDepthColumnVisible}" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnBitrate}" Binding="{Binding Track.BitrateDisplay}" IsVisible="{Binding IsBitrateColumnVisible}" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnFileType}" Binding="{Binding Track.FileType}" IsVisible="{Binding IsFileTypeColumnVisible}" />
                    <DataGridTextColumn Header="{x:Static res:Strings.ColumnYear}" Binding="{Binding Track.Year}" IsVisible="{Binding IsYearColumnVisible}" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>

</UserControl>
