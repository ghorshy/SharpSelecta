<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SharpSelecta.App.ViewModels"
             xmlns:res="using:SharpSelecta.App.Resources"
             xmlns:core="using:SharpSelecta.Core.Library"
             xmlns:views="using:SharpSelecta.App.Views"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:styles="using:SharpSelecta.App.Styles"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="700" d:DesignHeight="400"
             x:Class="SharpSelecta.App.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

    <DockPanel LastChildFill="True">
        <!-- Temporary: minimal view-mode switcher, not yet styled to show which one is active. -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="{styles:SpacingValue XS}"
                    Margin="{styles:Spacing Bottom=XS}" IsVisible="{Binding HasTracks}">
            <Button Content="List" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static core:LibraryViewMode.TrackList}" />
            <Button Content="Albums" Command="{Binding SetViewModeCommand}" CommandParameter="{x:Static core:LibraryViewMode.AlbumGrid}" />
        </StackPanel>

    <Grid>
        <!-- Empty state: no library folder chosen (or remembered) yet — the button takes center
             stage as an invitation, instead of sitting small at the top above an empty list.
             Gated on ShowEmptyState (NoTracks AND NOT loading), not NoTracks alone, so this
             doesn't flash up misleadingly while a remembered folder is still being (re)scanned. -->
        <StackPanel IsVisible="{Binding ShowEmptyState}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="{styles:SpacingValue M}">
            <Button Content="{x:Static res:Strings.ChooseLibraryFolder}" Command="{Binding AddFolderCommand}" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="OrangeRed" TextWrapping="Wrap" HorizontalAlignment="Center" IsVisible="{Binding StatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
        </StackPanel>

        <StackPanel IsVisible="{Binding IsLoadingLibrary}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="{styles:SpacingValue M}">
            <ProgressBar IsIndeterminate="True" Width="200" />
            <TextBlock Text="{x:Static res:Strings.LoadingLibrary}" HorizontalAlignment="Center" />
        </StackPanel>

        <Border IsVisible="{Binding IsAlbumGridViewVisible}">
            <views:AlbumGridView DataContext="{Binding Grid}" />
        </Border>

        <DockPanel IsVisible="{Binding IsTrackListViewVisible}" LastChildFill="True">
            <DataGrid x:Name="TracksGrid"
                      ItemsSource="{Binding Tracks}"
                      AutoGenerateColumns="False"
                      CanUserSortColumns="True"
                      CanUserResizeColumns="True"
                      CanUserReorderColumns="True"
                      IsReadOnly="True"
                      GridLinesVisibility="Horizontal"
                      DoubleTapped="OnTrackDoubleTapped"
                      ColumnReordered="OnColumnReordered">
                <!-- No built-in default — without this, dragging a column header to reorder it
                     shows no indicator of where it will land. Height is fixed rather than clipped
                     to the header row automatically, so it's sized to match it explicitly. -->
                <DataGrid.DropLocationIndicatorTemplate>
                    <Template>
                        <Border Width="2" Height="32" Background="{DynamicResource SystemAccentColor}" />
                    </Template>
                </DataGrid.DropLocationIndicatorTemplate>

                <DataGrid.Styles>
                    <!-- DataGrid's bundled theme uses its own larger default instead of the rest
                         of the app's Fluent-theme content font size — match it explicitly. -->
                    <Style Selector="DataGridCell">
                        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
                    </Style>

                    <!-- Rows are IsReadOnly, so the per-cell "current cell" indicator the bundled
                         theme draws on click doesn't serve editing focus — just row selection,
                         which the row highlight already shows. It's an inner Rectangle in
                         DataGridCell's own control template (not bound to the cell's own
                         BorderBrush/BorderThickness), toggled visible via these pseudo-classes. -->
                    <Style Selector="DataGridCell:current /template/ Rectangle">
                        <Setter Property="IsVisible" Value="False" />
                    </Style>
                    <Style Selector="DataGridCell:focus /template/ Rectangle">
                        <Setter Property="IsVisible" Value="False" />
                    </Style>
                    <Style Selector="DataGridCell:focus-visible /template/ Rectangle">
                        <Setter Property="IsVisible" Value="False" />
                    </Style>

                    <!-- Right-click on a column header: choose which columns are visible. -->
                    <Style Selector="DataGridColumnHeader">
                        <Setter Property="FontSize" Value="{DynamicResource ControlContentThemeFontSize}" />
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu>
                                    <ContextMenu.Styles>
                                        <Style Selector="MenuItem">
                                            <Setter Property="StaysOpenOnClick" Value="True" />
                                        </Style>
                                    </ContextMenu.Styles>
                                    <MenuItem Header="{x:Static res:Strings.ColumnTrack}" ToggleType="CheckBox" IsChecked="{Binding IsTrackNumberColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnTitle}" ToggleType="CheckBox" IsChecked="{Binding IsTitleColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnArtist}" ToggleType="CheckBox" IsChecked="{Binding IsArtistColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnAlbum}" ToggleType="CheckBox" IsChecked="{Binding IsAlbumColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnLength}" ToggleType="CheckBox" IsChecked="{Binding IsLengthColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnSampleRate}" ToggleType="CheckBox" IsChecked="{Binding IsSampleRateColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnBitDepth}" ToggleType="CheckBox" IsChecked="{Binding IsBitDepthColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnBitrate}" ToggleType="CheckBox" IsChecked="{Binding IsBitrateColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnFileType}" ToggleType="CheckBox" IsChecked="{Binding IsFileTypeColumnVisible, Mode=TwoWay}" />
                                    <MenuItem Header="{x:Static res:Strings.ColumnYear}" ToggleType="CheckBox" IsChecked="{Binding IsYearColumnVisible, Mode=TwoWay}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>

                    <!-- Right-click on a row: same Play Now/Play Next/Add to Queue actions as
                         before, now on DataGridRow instead of ListBoxItem. -->
                    <Style Selector="DataGridRow">
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu x:DataType="vm:LibraryTrackViewModel">
                                    <MenuItem Header="{x:Static res:Strings.PlayNow}"
                                              Command="{Binding Library.PlayNowCommand}"
                                              CommandParameter="{Binding Track}" />
                                    <MenuItem Header="{x:Static res:Strings.PlayNext}"
                                              Command="{Binding Library.PlayNextCommand}"
                                              CommandParameter="{Binding Track}" />
                                    <MenuItem Header="{x:Static res:Strings.AddToQueue}"
                                              Command="{Binding Library.AddToQueueCommand}"
                                              CommandParameter="{Binding Track}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </DataGrid.Styles>

                <DataGrid.Columns>
                    <DataGridTextColumn Tag="TrackNumber" Header="{x:Static res:Strings.ColumnTrack}" Binding="{Binding Track.TrackNumber}" IsVisible="{Binding IsTrackNumberColumnVisible}" Width="60" />
                    <DataGridTextColumn Tag="Title" Header="{x:Static res:Strings.ColumnTitle}" Binding="{Binding Track.Title}" IsVisible="{Binding IsTitleColumnVisible}" Width="200" />
                    <DataGridTextColumn Tag="Artist" Header="{x:Static res:Strings.ColumnArtist}" Binding="{Binding Track.Artist}" IsVisible="{Binding IsArtistColumnVisible}" Width="150" />
                    <DataGridTextColumn Tag="Album" Header="{x:Static res:Strings.ColumnAlbum}" Binding="{Binding Track.Album}" IsVisible="{Binding IsAlbumColumnVisible}" Width="150" />
                    <DataGridTextColumn Tag="Length" Header="{x:Static res:Strings.ColumnLength}" Binding="{Binding LengthDisplay}" SortMemberPath="Track.Duration" IsVisible="{Binding IsLengthColumnVisible}" Width="80" />
                    <DataGridTextColumn Tag="SampleRate" Header="{x:Static res:Strings.ColumnSampleRate}" Binding="{Binding SampleRateDisplay}" SortMemberPath="Track.SampleRate" IsVisible="{Binding IsSampleRateColumnVisible}" Width="100" />
                    <DataGridTextColumn Tag="BitDepth" Header="{x:Static res:Strings.ColumnBitDepth}" Binding="{Binding BitDepthDisplay}" SortMemberPath="Track.BitDepth" IsVisible="{Binding IsBitDepthColumnVisible}" Width="80" />
                    <DataGridTextColumn Tag="Bitrate" Header="{x:Static res:Strings.ColumnBitrate}" Binding="{Binding BitrateDisplay}" SortMemberPath="Track.Bitrate" IsVisible="{Binding IsBitrateColumnVisible}" Width="90" />
                    <DataGridTextColumn Tag="FileType" Header="{x:Static res:Strings.ColumnFileType}" Binding="{Binding Track.FileType}" IsVisible="{Binding IsFileTypeColumnVisible}" Width="80" />
                    <DataGridTextColumn Tag="Year" Header="{x:Static res:Strings.ColumnYear}" Binding="{Binding Track.Year}" IsVisible="{Binding IsYearColumnVisible}" Width="60" />
                </DataGrid.Columns>
            </DataGrid>
        </DockPanel>
    </Grid>
    </DockPanel>

</UserControl>
