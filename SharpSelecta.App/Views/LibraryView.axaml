<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SharpSelecta.App.ViewModels"
             xmlns:res="using:SharpSelecta.App.Resources"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="500" d:DesignHeight="400"
             x:Class="SharpSelecta.App.Views.LibraryView"
             x:DataType="vm:LibraryViewModel">

    <Grid>
        <!-- Empty state: no library folder chosen (or remembered) yet — the button takes center
             stage as an invitation, instead of sitting small at the top above an empty list. -->
        <StackPanel IsVisible="{Binding NoTracks}" HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="10">
            <Button Content="{x:Static res:Strings.ChooseLibraryFolder}" Command="{Binding ChooseFolderCommand}" HorizontalAlignment="Center" />
            <TextBlock Text="{Binding StatusMessage}" Foreground="OrangeRed" TextWrapping="Wrap" HorizontalAlignment="Center" IsVisible="{Binding StatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
        </StackPanel>

        <DockPanel IsVisible="{Binding HasTracks}" LastChildFill="True">
            <StackPanel DockPanel.Dock="Top" Spacing="10" Margin="0,0,0,10">
                <Button Content="{x:Static res:Strings.ChooseLibraryFolder}" Command="{Binding ChooseFolderCommand}" HorizontalAlignment="Left" />
                <TextBlock Text="{Binding StatusMessage}" Foreground="OrangeRed" TextWrapping="Wrap" IsVisible="{Binding StatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
            </StackPanel>

            <ListBox ItemsSource="{Binding Tracks}" DoubleTapped="OnTrackDoubleTapped">
                <!-- ContextMenu lives on ListBoxItem itself (via style), not on the DataTemplate's
                     content — the item container is what actually covers the full row including
                     its own padding, so this is the only way right-click works across the whole
                     row instead of just the text glyphs (Avalonia issue #15942 strikes again). -->
                <ListBox.Styles>
                    <Style Selector="ListBoxItem">
                        <Setter Property="ContextMenu">
                            <Setter.Value>
                                <ContextMenu x:DataType="vm:LibraryTrackViewModel">
                                    <MenuItem Header="{x:Static res:Strings.PlayNow}"
                                              Command="{Binding Library.PlayNowCommand}"
                                              CommandParameter="{Binding Track}" />
                                    <MenuItem Header="{x:Static res:Strings.PlayNext}"
                                              Command="{Binding Library.PlayNextCommand}"
                                              CommandParameter="{Binding Track}" />
                                    <MenuItem Header="{x:Static res:Strings.AddToQueue}"
                                              Command="{Binding Library.AddToQueueCommand}"
                                              CommandParameter="{Binding Track}" />
                                </ContextMenu>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.Styles>
                <ListBox.ItemTemplate>
                    <DataTemplate x:DataType="vm:LibraryTrackViewModel">
                        <TextBlock Text="{Binding DisplayName}" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </DockPanel>
    </Grid>

</UserControl>
