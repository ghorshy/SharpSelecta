<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:SharpSelecta.App.ViewModels"
        xmlns:res="using:SharpSelecta.App.Resources"
        xmlns:conv="using:Avalonia.Data.Converters"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="400" d:DesignHeight="450"
        x:Class="SharpSelecta.App.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Title="SharpSelecta"
        Width="400"
        Height="450">

    <StackPanel Margin="10" Spacing="10">
        <TextBlock Text="{Binding DisplayFileName}" />
        <StackPanel Orientation="Horizontal" Spacing="10">
            <Button Content="{x:Static res:Strings.OpenFile}" Command="{Binding OpenFileCommand}" />
            <Button Content="{Binding PlayPauseLabel}" Command="{Binding PlayPauseCommand}" />
        </StackPanel>
        <TextBlock Text="{Binding StatusMessage}" Foreground="OrangeRed" TextWrapping="Wrap" IsVisible="{Binding StatusMessage, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
    </StackPanel>

</Window>