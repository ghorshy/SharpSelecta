<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SharpSelecta.App.ViewModels"
             xmlns:views="using:SharpSelecta.App.Views"
             xmlns:converters="using:SharpSelecta.App.Converters"
             xmlns:conv="using:Avalonia.Data.Converters"
             xmlns:styles="using:SharpSelecta.App.Styles"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="220" d:DesignHeight="260"
             x:Class="SharpSelecta.App.Views.NowPlayingView"
             x:DataType="vm:PlaybackControlsViewModel">

    <StackPanel Spacing="{styles:SpacingValue XS}" IsVisible="{Binding CurrentTrack, Converter={x:Static conv:ObjectConverters.IsNotNull}}">
        <TextBlock Text="{Binding CurrentTrack.Title}" FontWeight="Bold" TextWrapping="Wrap" />
        <TextBlock Text="{Binding CurrentTrack.Artist}" TextWrapping="Wrap" />
        <TextBlock Text="{Binding CurrentTrack.Album}" TextWrapping="Wrap" />
        <TextBlock Text="{Binding CurrentTrack.Year}" />
        <TextBlock Text="{Binding CurrentTrackTechnicalSummary}" Opacity="0.7" FontSize="11" TextWrapping="Wrap" />
        <!-- Double-tap opens the cover at its real resolution in a separate borderless window
             (AlbumCoverWindow) - only meaningful when there's actual artwork, hence the guard in
             the handler rather than gating this Panel's own visibility. -->
        <Panel Margin="{styles:Spacing Top=S}" DoubleTapped="OnArtworkDoubleTapped">
            <Image Source="{Binding CurrentTrackArtworkBytes, Converter={x:Static converters:ArtworkConverter.Instance}}"
                   Stretch="Uniform"
                   HorizontalAlignment="Stretch"
                   IsVisible="{Binding CurrentTrackArtworkBytes, Converter={x:Static conv:ObjectConverters.IsNotNull}}" />
            <views:AlbumCoverPlaceholderIcon HorizontalAlignment="Stretch"
                                             IsVisible="{Binding CurrentTrackArtworkBytes, Converter={x:Static conv:ObjectConverters.IsNull}}" />
        </Panel>
    </StackPanel>

</UserControl>
