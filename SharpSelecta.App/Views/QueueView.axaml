<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:SharpSelecta.App.ViewModels"
             xmlns:res="using:SharpSelecta.App.Resources"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d" d:DesignWidth="200" d:DesignHeight="400"
             x:Class="SharpSelecta.App.Views.QueueView"
             x:DataType="vm:QueueViewModel">

    <DockPanel LastChildFill="True">
        <TextBlock DockPanel.Dock="Top" Text="{x:Static res:Strings.Queue}" FontWeight="Bold" Margin="0,0,0,10" />

        <!-- Drag-and-drop reordering: a press only turns into a drag once the pointer actually
             moves past a small threshold (see code-behind) — DragDrop.AllowDrop here is what lets
             this ListBox accept the drop. -->
        <ListBox x:Name="QueueList"
                 ItemsSource="{Binding Entries}"
                 SelectedIndex="{Binding CurrentIndex, Mode=OneWay}"
                 DoubleTapped="OnEntryDoubleTapped"
                 DragDrop.AllowDrop="True">
            <ListBox.Styles>
                <!-- Right-click on an entry: Play Now / Remove from Queue. -->
                <Style Selector="ListBoxItem">
                    <Setter Property="ContextMenu">
                        <Setter.Value>
                            <ContextMenu x:DataType="vm:QueueEntryViewModel">
                                <MenuItem Header="{x:Static res:Strings.PlayNow}"
                                          Command="{Binding Queue.PlayEntryCommand}"
                                          CommandParameter="{Binding}" />
                                <MenuItem Header="{x:Static res:Strings.RemoveFromQueue}"
                                          Command="{Binding Queue.RemoveFromQueueCommand}"
                                          CommandParameter="{Binding}" />
                            </ContextMenu>
                        </Setter.Value>
                    </Setter>
                </Style>

                <!-- The row currently being dragged fades out a bit... -->
                <Style Selector="ListBoxItem.dragging">
                    <Setter Property="Opacity" Value="0.4" />
                </Style>

                <!-- ...and a line above whatever row is under the cursor shows where it will land. -->
                <Style Selector="ListBoxItem.drag-over">
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
                    <Setter Property="BorderThickness" Value="0,2,0,0" />
                </Style>

                <!-- Dragging past the last row (or into the empty space below the list) still
                     drops at the end of the queue — show the line below the last row instead. -->
                <Style Selector="ListBoxItem.drag-over-end">
                    <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}" />
                    <Setter Property="BorderThickness" Value="0,0,0,2" />
                </Style>
            </ListBox.Styles>
            <ListBox.ItemTemplate>
                <DataTemplate x:DataType="vm:QueueEntryViewModel">
                    <TextBlock Text="{Binding DisplayName}" TextWrapping="Wrap" />
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>

</UserControl>
